# Master API key for authenticating requests to the AI server
# openssl rand -hex 32
MASTER_APIKEY="0bde258c664317aa681d375339be089eed8f2f71f96bf69a12a1f6357ca804ba"

# Serper configuration
SERPER_API_KEY=""
SERPER_BASE_URL="https://google.serper.dev"

# ── LLM Provider Configuration ──────────────────────────────────────────────
# Choose which LLM provider to use. Chat defaults to OpenRouter free and can
# fall back to Gemini when OPENROUTER_API_KEY is unavailable or fails.
LLM_PROVIDER="openrouter"

# Default low-cost chat model
LLM_MODEL="openrouter/free"

# OpenRouter API key (FREE tier available)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Google Gemini API key (FREE tier available)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Groq API key (FREE tier available)
# Get yours at: https://console.groq.com/keys
# Free models: llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.
GROQ_API_KEY=""

# xAI / Grok API key (optional, beta access required)
# Get yours at: https://console.x.ai/
XAI_API_KEY=""

# Firecrawl API key (optional)
FIRECRAWL_API_KEY=""

# ChromaDB configuration
CHROMADB_PORT="8881"
CHROMADB_HOST="localhost"

# Apify API key
APIFY_APIKEY=

# Neon / Postgres connection string (used by ai-server Prisma for its own tables)
DATABASE_URL=""

# ── Module 1 ingestion ──────────────────────────────────────────────────────
# Base URL of the Node/Express server (used to push scraped data into Module 1 tables)
SERVER_BASE_URL="http://localhost:8000"
# Shared secret — must match INGEST_API_KEY on the server
INGEST_API_KEY=""
