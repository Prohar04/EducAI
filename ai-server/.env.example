# Master API key for authenticating requests to the AI server
# openssl rand -hex 32
MASTER_APIKEY=""   # openssl rand -hex 32

# ── Job Finder API Keys — same values as server/.env ─────────────────────────
# Adzuna and JSearch are called directly from the FastAPI AI server.
# OpenAI is already configured above — no extra key needed for Job Finder fallback.
#
# SOURCE 1: Adzuna API (primary — 16 countries, official, reliable)
# Free: 1,000 req/day | Docs: developer.adzuna.com
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# SOURCE 2: JSearch via RapidAPI (fallback — all other countries)
# Free: 200 req/month. Get at rapidapi.com — search "JSearch"
RAPIDAPI_KEY=

# Serper configuration
SERPER_API_KEY=""
SERPER_BASE_URL="https://google.serper.dev"

# ── LLM Provider Configuration ──────────────────────────────────────────────
# Primary provider: Official OpenAI API (recommended)
# Set OPENAI_API_KEY for direct GPT-4o-mini access — best quality and reliability.
# If unset, falls back to Groq → OpenRouter → Gemini → xAI in that order.
OPENAI_API_KEY=""

# Optional: override provider and model explicitly
# LLM_PROVIDER="openai"   # openai | groq | openrouter | gemini | xai
# LLM_MODEL="gpt-4o-mini"
LLM_PROVIDER=""
LLM_MODEL=""

# OpenRouter API key (fallback, FREE tier available)
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=""

# Google Gemini API key (FREE tier available)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Groq API key (FREE tier available)
# Get yours at: https://console.groq.com/keys
# Free models: llama-3.3-70b-versatile, mixtral-8x7b-32768, etc.
GROQ_API_KEY=""

# xAI / Grok API key (optional, beta access required)
# Get yours at: https://console.x.ai/
XAI_API_KEY=""

# Firecrawl API key (optional)
FIRECRAWL_API_KEY=""

# ChromaDB configuration
CHROMADB_PORT="8881"
CHROMADB_HOST="localhost"

# Apify API key
APIFY_APIKEY=

# Neon / Postgres connection string (used by ai-server Prisma for its own tables)
DATABASE_URL=""

# ── Module 1 ingestion ──────────────────────────────────────────────────────
# Base URL of the Node/Express server (used to push scraped data into Module 1 tables)
SERVER_BASE_URL="http://localhost:8000"
# Shared secret — must match INGEST_API_KEY on the server
INGEST_API_KEY=""
