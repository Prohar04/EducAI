# ╔══════════════════════════════════════════════════════════════════╗
# ║                    EducAI — Environment Variables               ║
# ║  Copy this file to .env and fill in the required values         ║
# ╚══════════════════════════════════════════════════════════════════╝

# ─── Docker / Compose (local dev only) ────────────────────────────
POSTGRES_USER=educai
POSTGRES_PASSWORD=                         # ⚠️  REQUIRED — your PostgreSQL password
POSTGRES_DB=educai

# ─── Server (Express API) — server/.env ──────────────────────────
PORT=8000
NODE_ENV=development                       # development | production
LOG_LEVEL=info

# Database
# Production (Neon / Render): set DATABASE_URL — takes highest priority
DATABASE_URL=                              # ⚠️  REQUIRED in production (Neon connection string)
DATABASE_URL_LOCAL=postgresql://educai:YOUR_PASSWORD@localhost:5432/educai   # ⚠️  for local dev
DATABASE_URL_CLOUD=                        # legacy alias for production DB (use DATABASE_URL instead)

# Security — Arcjet (optional — server starts without it)
ARCJET_KEY=                                # optional — https://arcjet.com

# Cron / scheduled jobs
CRON_SECRET=                               # ⚠️  REQUIRED in production — generate: openssl rand -base64 32

# Express session
SESSION_SECRET=                            # ⚠️  REQUIRED — generate: openssl rand -base64 32

# JWT
JWT_SECRET=                                # ⚠️  REQUIRED — generate: openssl rand -base64 32
JWT_EXPIRES_IN=15m
REFRESH_JWT_SECRET=                        # ⚠️  REQUIRED — generate: openssl rand -base64 32 (different value)
REFRESH_JWT_EXPIRES_IN=15d

# Google OAuth
GOOGLE_CLIENT_ID=                          # ⚠️  REQUIRED — Google Cloud Console
GOOGLE_CLIENT_SECRET=                      # ⚠️  REQUIRED — Google Cloud Console
GOOGLE_CALLBACK_URL=http://localhost:8000/auth/google/callback
# Production: GOOGLE_CALLBACK_URL=https://<api>.onrender.com/auth/google/callback

# Frontend URL (for CORS & redirects)
# Production: set to your Vercel URL, comma-separate multiple origins
FRONTEND_URL=http://localhost:3000
# Production: FRONTEND_URL=https://educai.vercel.app

AI_SERVER_URL=http://localhost:8001
# Production: AI_SERVER_URL=https://<ai-server>.onrender.com

AI_SERVER_API_KEY=                         # ⚠️  REQUIRED — must match MASTER_APIKEY on ai-server
CHAT_RATE_LIMIT_PER_MIN=20

# Email (Resend)
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=465
EMAIL_SECURE=true
EMAIL_USER=resend
EMAIL_PASS=                                # ⚠️  REQUIRED — Resend API key (re_xxx) from https://resend.com
EMAIL_FROM="EducAI <noreply@educai.is-a.dev>"

# ─── Web (Next.js) — web/.env ───────────────────────────────────
SESSION_SECRET_KEY=                        # ⚠️  REQUIRED — generate: openssl rand -base64 32
BACKEND_URL=http://localhost:8000
# Production: BACKEND_URL=https://<api>.onrender.com
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000
JWT_SECRET=                                # ⚠️  REQUIRED — must match server JWT_SECRET

# ─── AI Server (FastAPI) — ai-server/.env ────────────────────────
MASTER_APIKEY=                             # ⚠️  REQUIRED — generate: openssl rand -hex 32; must match server AI_SERVER_API_KEY
SERVER_BASE_URL=http://localhost:8000
# Production: SERVER_BASE_URL=https://<api>.onrender.com
INGEST_API_KEY=                            # must match server INGEST_API_KEY

LLM_PROVIDER=                              # openai | openrouter | gemini | groq | xai
LLM_MODEL=                                 # e.g. gpt-4o-mini
OPENAI_API_KEY=                            # recommended
OPENROUTER_API_KEY=                        # free-tier fallback — https://openrouter.ai/keys
GEMINI_API_KEY=                            # free-tier fallback — https://aistudio.google.com
GROQ_API_KEY=                              # free-tier fallback — https://console.groq.com

SERPER_API_KEY=                            # optional — web search
FIRECRAWL_API_KEY=                         # optional — page extraction

# Optional — ChromaDB (vector search / RAG); leave empty on Render free tier
CHROMADB_HOST=
CHROMADB_PORT=8881

# Optional — Apify (web scraping); leave empty if not using
APIFY_APIKEY=
