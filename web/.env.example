# Web (Next.js) — Environment Variables
# Copy this file to .env and fill in the values

NODE_ENV=development
SESSION_SECRET_KEY=                    # REQUIRED — generate with: openssl rand -base64 32
BACKEND_URL=http://localhost:8000      # URL of the Express API server
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000   # public URL of this web app
