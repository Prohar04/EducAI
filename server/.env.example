
# Server configuration
PORT=
NODE_ENV=
LOG_LEVEL=

# Database configuration
# Override: set this to force a specific connection URL regardless of NODE_ENV
# Recommended: point to Neon pooler URL for all environments
DATABASE_URL=
# Neon cloud connection string (pooler endpoint)
DATABASE_URL_CLOUD=
# Local Postgres URL for development
DATABASE_URL_LOCAL=
# Set to 'production' to allow migrate dev/reset against a remote DB (use with caution)
PRISMA_MIGRATE_ENV=
# Set to 'true' to allow seeding (db:seed:safe)
SEED_ENABLED=

# Arcjet configuration
ARCJET_KEY=

# JWT configuration
JWT_SECRET=
JWT_EXPIRES_IN="15min"

REFRESH_JWT_SECRET=
REFRESH_JWT_EXPIRES_IN="15d" 


# Google Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Frontend
FRONTEND_URL=http://localhost:3000

# AI assistant — must match the port uvicorn is started on (default 8001)
AI_SERVER_URL=http://localhost:8001
CHAT_RATE_LIMIT_PER_MIN=20

# Email
# EMAIL_PROVIDER=console  → print links to stdout (no SMTP needed, good for local dev)
# EMAIL_PROVIDER=smtp     → send via Gmail App Password (default when creds present)
EMAIL_PROVIDER=console
EMAIL_USER=                            # your Gmail address (e.g. you@gmail.com)
EMAIL_PASS=                            # 16-char Google App Password (no spaces)
EMAIL_FROM="EducAI <you@gmail.com>"    # displayed From address

# Cookie configuration
COOKIE_SAME_SITE=

# Session
SESSION_SECRET=

# Testing
TEST_DATABASE_URL=

# Module 1 ingestion shared secret
# Must match INGEST_API_KEY in ai-server/.env
INGEST_API_KEY=

# Scholarship deadline alerts
# CRON_SECRET: shared secret for the POST /deadline-alerts/run endpoint
# Set this in CI secrets or your scheduler (GitHub Actions, Vercel cron, etc.)
# If empty, the endpoint is unprotected — set it in production!
CRON_SECRET=

# ── AI Providers (REQUIRED for production features) ───────────────────────────
# Without these, SOP Builder, CV Builder, Professor Finder, and chat will not work.

# Option A: OpenAI direct (recommended for best quality)
OPENAI_API_KEY=          # sk-...  from https://platform.openai.com/api-keys

# Option B: OpenRouter (cheaper proxy to GPT-4o-mini and other models)
OPENROUTER_API_KEY=      # sk-or-... from https://openrouter.ai/keys

# IMPORTANT: Set at least one of OPENAI_API_KEY or OPENROUTER_API_KEY.
# OPENAI_API_KEY takes priority if both are set.

# ── Serper (REQUIRED for Professor Finder and NLP search) ────────────────────
# Without this, Professor Finder returns a 503 "not configured" error.
# Get a key at https://serper.dev (free tier: 2,500 searches/month)
SERPER_API_KEY=          # from https://serper.dev/api-key

# ── Production secrets (REQUIRED in GitHub Actions for Data Sync) ─────────────
# Set BACKEND_URL and CRON_SECRET as GitHub Actions repo secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# BACKEND_URL = https://your-backend.onrender.com   (no trailing slash)
# CRON_SECRET = (same value as CRON_SECRET below, used by the data-sync workflow)

# ── Live Scholarship Refresh Pipeline ─────────────────────────────────────────
# SERPER_API_KEY is required for live scholarship discovery (Serper web search).
# OPENAI_API_KEY or OPENROUTER_API_KEY is required for LLM extraction of results.
# If SERPER_API_KEY is absent, the live refresh step is silently skipped.
# SERPER_API_KEY=       # already listed above — required for live scholarship search
# OPENAI_API_KEY=       # already listed above — used for gpt-4o-mini extraction
# OPENROUTER_API_KEY=   # already listed above — alternative to OPENAI_API_KEY

# ─────────────────────────────────────────────────────────────────────────────
# Job Finder API Keys
# ─────────────────────────────────────────────────────────────────────────────
#
# SOURCE 1: Adzuna API (primary — 16 countries, official, reliable)
# Free: 1,000 req/day | Docs: developer.adzuna.com
#
# HOW TO GET (2 minutes):
#   1. Go to https://developer.adzuna.com
#   2. Click "Register" and create a free account
#   3. Go to "API Access Details" in your dashboard
#   4. Copy your App ID and App Key
#   5. Paste both below
#
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# SOURCE 2: JSearch via RapidAPI (fallback — all other countries)
# Free: 200 req/month | Basic: $10/mo for 2,000 req
# Docs: rapidapi.com — search "JSearch"
#
# HOW TO GET (2 minutes):
#   1. Go to https://rapidapi.com and sign up
#   2. Search "JSearch" → click result by letscrape
#   3. Subscribe to FREE plan
#   4. Go to Endpoints tab → copy X-RapidAPI-Key from right panel
#   5. Paste below
#
RAPIDAPI_KEY=

# SOURCE 3: OpenAI (last resort fallback — already used by EducAI)
# Uses the existing OPENAI_API_KEY already configured above.
# No additional key needed for Job Finder fallback.
# ─────────────────────────────────────────────────────────────────────────────

# ── AI Server pipeline (internal) ─────────────────────────────────────────────
# Shared secret between this server and the ai-server Firecrawl pipeline.
# Used by the programs sync pipeline (POST /api/v1/module1/sync).
MASTER_APIKEY=           # shared secret for ai-server → must match ai-server MASTER_APIKEY

# ── Live Program Data Pipeline (REQUIRED for source-backed program discovery) ─
# Without these, programs are served from the last sync only (cached/stale).
# The ai-server uses Firecrawl to scrape university pages and extract programme
# details, and Serper to run targeted search queries.
#
# FIRECRAWL_API_KEY  — from https://firecrawl.dev  (scrapes official university pages)
# SERPER_API_KEY     — already listed above         (drives search queries)
# OPENAI_API_KEY     — already listed above         (LLM extraction of programme data)
#
# If FIRECRAWL_API_KEY is absent the ai-server sync pipeline will not run and the
# Programs section will display only previously cached data with a Stale badge.
# FIRECRAWL_API_KEY= # Set in ai-server/.env (not here)

# ── Supabase Storage (for Gap Fix evidence uploads) ──────────────────────────
# Used to store PDF evidence for Gap Fix verification
# Get these from your Supabase project → Settings → API
SUPABASE_URL=                # https://your-project.supabase.co
SUPABASE_SERVICE_KEY=        # service_role key — NEVER expose to frontend
# Configurable bucket name (default: "evidence")
# Create this bucket in Supabase dashboard → Storage → New bucket
# IMPORTANT: Keep the bucket PRIVATE (not public). Use signed URLs or server-side
# access for downloads. Evidence files may contain sensitive user documents.
SUPABASE_EVIDENCE_BUCKET=evidence
