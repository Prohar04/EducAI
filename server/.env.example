
# Server configuration
PORT=
NODE_ENV=
LOG_LEVEL=

# Database configuration
# Override: set this to force a specific connection URL regardless of NODE_ENV
# Recommended: point to Neon pooler URL for all environments
DATABASE_URL=
# Neon cloud connection string (pooler endpoint)
DATABASE_URL_CLOUD=
# Local Postgres URL for development
DATABASE_URL_LOCAL=
# Set to 'production' to allow migrate dev/reset against a remote DB (use with caution)
PRISMA_MIGRATE_ENV=
# Set to 'true' to allow seeding (db:seed:safe)
SEED_ENABLED=

# Arcjet configuration
ARCJET_KEY=

# JWT configuration
JWT_SECRET=
JWT_EXPIRES_IN="15min"

REFRESH_JWT_SECRET=
REFRESH_JWT_EXPIRES_IN="15d" 


# Google Auth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=

# Frontend
FRONTEND_URL=http://localhost:3000

# AI assistant — must match the port uvicorn is started on (default 8001)
AI_SERVER_URL=http://localhost:8001
CHAT_RATE_LIMIT_PER_MIN=20

# Email
# EMAIL_PROVIDER=console  → print links to stdout (no SMTP needed, good for local dev)
# EMAIL_PROVIDER=smtp     → send via Gmail App Password (default when creds present)
EMAIL_PROVIDER=console
EMAIL_USER=                            # your Gmail address (e.g. you@gmail.com)
EMAIL_PASS=                            # 16-char Google App Password (no spaces)
EMAIL_FROM="EducAI <you@gmail.com>"    # displayed From address

# Cookie configuration
COOKIE_SAME_SITE=

# Session
SESSION_SECRET=

# Testing
TEST_DATABASE_URL=

# Module 1 ingestion shared secret
# Must match INGEST_API_KEY in ai-server/.env
INGEST_API_KEY=

# Scholarship deadline alerts
# CRON_SECRET: shared secret for the POST /deadline-alerts/run endpoint
# Set this in CI secrets or your scheduler (GitHub Actions, Vercel cron, etc.)
# If empty, the endpoint is unprotected — set it in production!
CRON_SECRET=

# ── AI Providers (REQUIRED for production features) ───────────────────────────
# Without these, SOP Builder, CV Builder, Professor Finder, and chat will not work.

# Option A: OpenAI direct (recommended for best quality)
OPENAI_API_KEY=          # sk-...  from https://platform.openai.com/api-keys

# Option B: OpenRouter (cheaper proxy to GPT-4o-mini and other models)
OPENROUTER_API_KEY=      # sk-or-... from https://openrouter.ai/keys

# IMPORTANT: Set at least one of OPENAI_API_KEY or OPENROUTER_API_KEY.
# OPENAI_API_KEY takes priority if both are set.

# ── Serper (REQUIRED for Professor Finder and NLP search) ────────────────────
# Without this, Professor Finder returns a 503 "not configured" error.
# Get a key at https://serper.dev (free tier: 2,500 searches/month)
SERPER_API_KEY=          # from https://serper.dev/api-key

# ── Production secrets (REQUIRED in GitHub Actions for Data Sync) ─────────────
# Set BACKEND_URL and CRON_SECRET as GitHub Actions repo secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# BACKEND_URL = https://your-backend.onrender.com   (no trailing slash)
# CRON_SECRET = (same value as CRON_SECRET below, used by the data-sync workflow)
